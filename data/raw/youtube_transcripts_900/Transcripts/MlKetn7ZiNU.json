[
  {
    "text": "I must return to the city\nto tell the others.",
    "start": 116.22,
    "duration": 1.9
  },
  {
    "text": "Come with us.",
    "start": 121.1,
    "duration": 1.25
  },
  {
    "text": "Woman, why weepest thou?",
    "start": 170.67,
    "duration": 1.25
  },
  {
    "text": "whom seekest thou?",
    "start": 174.515,
    "duration": 3.477
  },
  {
    "text": "Sir, if thou have borne him\nhence, tell me where thou hast",
    "start": 177.992,
    "duration": 7.044
  },
  {
    "text": "laid him, and I will\ntake him away.",
    "start": 185.036,
    "duration": 2.477
  },
  {
    "text": "Mary.",
    "start": 192.343,
    "duration": 1.25
  },
  {
    "text": "Rabboni.",
    "start": 196.22,
    "duration": 0.58
  },
  {
    "text": "Touch me not; for I am not yet\nascended to my Father: but go",
    "start": 196.8,
    "duration": 7.56
  },
  {
    "text": "to my brethren, and say unto\nthem, I ascend unto my Father,",
    "start": 204.36,
    "duration": 5.37
  },
  {
    "text": "and your Father; and to\nmy God, and your God.",
    "start": 209.73,
    "duration": 5.93
  }
]