  {
    "text": "(snorts)",
    "start": 278.152,
    "duration": 1.123
  },
  {
    "text": "(Essie) Whoa, check it out.",
    "start": 279.275,
    "duration": 1.911
  },
  {
    "text": "It's Mummy Pig.",
    "start": 281.186,
    "duration": 1.438
  },
  {
    "text": "Ooh, Mummy Pig, I like your dress.",
    "start": 282.984,
    "duration": 2.423
  },
  {
    "text": "It's yellow with some flowers.",
    "start": 285.407,
    "duration": 3.083
  },
  {
    "text": "Mummy Pig has yellow play-doh.",
    "start": 289.15,
    "duration": 3.18
  },
  {
    "text": "(boink) Oops, sorry.",
