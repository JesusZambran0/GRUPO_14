    "text": "Choo-choo!",
    "start": 127.285,
    "duration": 1.473
  },
  {
    "text": "Here is our train.",
    "start": 129.39,
    "duration": 1.371
  },
  {
    "text": "Ta-da!",
    "start": 139.621,
    "duration": 1.222
  },
  {
    "text": "(mimics train sound)",
    "start": 141.112,
