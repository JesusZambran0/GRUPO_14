  },
  {
    "text": "[Music]",
    "start": 231.84,
    "duration": 3.099
  },
  {
    "text": "No. Wait. No. No.",
    "start": 234.959,
    "duration": 3.521
  },
  {
    "text": "Wait. No. It's not safe.",
    "start": 239.48,
    "duration": 7.16
  },
  {
    "text": "Wake up. Wake up. Wake up. Wake up. Wake",
    "start": 244.4,
