[
  {
    "text": "(Earth rumbling)",
    "start": 0.397,
    "duration": 2.75
  },
  {
    "text": "(title ringing)",
    "start": 4.638,
    "duration": 2.667
  },
  {
    "text": "(radio chattering)",
    "start": 10.207,
    "duration": 1.807
  },
  {
    "text": "(dramatic music)",
    "start": 12.014,
    "duration": 2.75
  },
  {
    "text": "(ISS whooshing)",
    "start": 20.141,
    "duration": 2.667
  },
  {
    "text": "♪ Come on and take a free ride ♪",
    "start": 24.706,
    "duration": 3.37
  },
  {
    "text": "♪ Yeah, yeah, yeah, yeah ♪",
    "start": 28.076,
    "duration": 4.194
  },
  {
    "text": "♪ Come on and take a free ride ♪",
    "start": 32.27,
    "duration": 3.451
  },
  {
    "text": "♪ Yeah, yeah, yeah, yeah ♪",
    "start": 35.721,
    "duration": 2.799
  },
  {
    "text": "- Commander, we are good for pre-flight.",
    "start": 38.52,
    "duration": 3.737
  },
  {
    "text": "- [Ethan] Roger that.",
    "start": 42.257,
    "duration": 1.325
  },
  {
    "text": "♪ Yeah, yeah, yeah, yeah ♪",
    "start": 43.582,
    "duration": 0.833
  },
  {
    "text": "- Standby for final\ntelemetry upload and lock.",
    "start": 44.415,
    "duration": 2.795
  },
  {
    "text": "Oh, and the crew hope you're enjoying",
    "start": 47.21,
    "duration": 3.23
  },
  {
    "text": "your send off serenade.",
    "start": 50.44,
    "duration": 1.888
  },
  {
    "text": "♪ Yeah, yeah, ooh, hoo ♪",
    "start": 52.328,
    "duration": 1.142
  },
  {
    "text": "- It's perfect, thank you.",
    "start": 53.47,
    "duration": 1.09
  },
  {
    "text": "- [Sarah] Thought you'd like it.",
    "start": 54.56,
    "duration": 2.308
  },
  {
    "text": "♪ Take a free ride ♪\n- Standby for final checks",
    "start": 56.868,
    "duration": 1.452
  },
  {
    "text": "and transmission tests.",
    "start": 58.32,
    "duration": 1.114
  },
  {
    "text": "♪ Yeah, yeah, yeah, yeah ♪",
    "start": 59.434,
    "duration": 0.833
  },
  {
    "text": "- Five by five, Flight.",
    "start": 60.267,
    "duration": 0.833
  },
  {
    "text": "Ready to disengage.",
    "start": 61.1,
    "duration": 1.49
  },
  {
    "text": "- Proceed.",
    "start": 62.59,
    "duration": 0.833
  },
  {
    "text": "(dramatic music)",
    "start": 65.254,
    "duration": 2.75
  },
  {
    "text": "You are cleared for initial trust.",
    "start": 78.95,
    "duration": 1.993
  },
  {
    "text": "- Roger that, moving out, quarter impulse.",
    "start": 81.96,
    "duration": 2.811
  },
  {
    "text": "- [Sarah] Nerd!",
    "start": 84.771,
    "duration": 1.199
  },
  {
    "text": "- Card carrying.",
    "start": 85.97,
    "duration": 1.133
  },
  {
    "text": "And if you don't say make it so,",
    "start": 89.21,
    "duration": 1.32
  },
  {
    "text": "I'll be very disappointed.",
    "start": 90.53,
    "duration": 1.423
  },
  {
    "text": "- [Sarah] Noted, Commander.",
    "start": 92.802,
    "duration": 1.35
  },
  {
    "text": "Please proceed to drive initiation point.",
    "start": 95.24,
    "duration": 2.828
  },
  {
    "text": "- On my way.",
    "start": 98.068,
    "duration": 1.0
  },
  {
    "text": "See you soon.",
    "start": 107.517,
    "duration": 1.083
  },
  {
    "text": "- Ah, he's so fast!",
    "start": 113.156,
    "duration": 1.583
  },
  {
    "text": "(mellow music)",
    "start": 117.553,
    "duration": 2.583
  },
  {
    "text": "Someone's excited.",
    "start": 129.62,
    "duration": 1.363
  },
  {
    "text": "You're looking forward to playing",
    "start": 133.01,
    "duration": 0.833
  },
  {
    "text": "with your new toy, Commander?",
    "start": 133.843,
    "duration": 1.867
  },
  {
    "text": "- I am, but maybe don't tell anyone",
    "start": 136.769,
    "duration": 1.271
  },
  {
    "text": "you call it my toy, honey",
    "start": 138.04,
    "duration": 1.96
  },
  {
    "text": "They may ask us to cover\nthe trillion-dollar bill.",
    "start": 140.0,
    "duration": 3.387
  },
  {
    "text": "Hey.",
    "start": 148.198,
    "duration": 0.833
  },
  {
    "text": "Look at me.",
    "start": 150.427,
    "duration": 0.917
  },
  {
    "text": "I'm coming back.",
    "start": 153.65,
    "duration": 0.893
  },
  {
    "text": "I always do.",
    "start": 155.45,
    "duration": 0.833
  },
  {
    "text": "I wouldn't do this if I thought otherwise.",
    "start": 158.536,
    "duration": 1.427
  },
  {
    "text": "- You better.",
    "start": 161.336,
    "duration": 1.792
  },
  {
    "text": "- You can't get rid of me that easy.",
    "start": 163.128,
    "duration": 3.0
  },
  {
    "text": "(melancholy music)",
    "start": 168.681,
    "duration": 3.596
  },
  {
    "text": "(engine humming)",
    "start": 172.277,
    "duration": 2.75
  },
  {
    "text": "Flight, we are green across\nthe board, please confirm.",
    "start": 182.63,
    "duration": 2.213
  },
  {
    "text": "- [Sarah] Confirmed, Longshot.",
    "start": 184.843,
    "duration": 1.65
  },
  {
    "text": "- Disengaging interlocks.",
    "start": 187.439,
    "duration": 2.083
  },
  {
    "text": "Flight, we are a go for FTL burn.",
    "start": 197.736,
    "duration": 2.304
  },
  {
    "text": "It's now or never.",
    "start": 200.04,
    "duration": 1.45
  },
  {
    "text": "- [Sarah] God speed, Commander.",
    "start": 201.49,
    "duration": 1.123
  },
  {
    "text": "See you on the other side.",
    "start": 203.925,
    "duration": 1.984
  },
  {
    "text": "- Come on Flight, let's\nhear it, you can do it.",
    "start": 205.909,
    "duration": 2.717
  },
  {
    "text": "- Fine.",
    "start": 208.626,
    "duration": 0.833
  },
  {
    "text": "Make it so, Commander.",
    "start": 210.53,
    "duration": 1.483
  },
  {
    "text": "- [Ethan] There you go.",
    "start": 212.93,
    "duration": 0.858
  },
  {
    "text": "- [Reporter] The world awaits the test",
    "start": 213.788,
    "duration": 0.949
  },
  {
    "text": "of the very first faster-than-light\npropulsion system.",
    "start": 214.737,
    "duration": 3.563
  },
  {
    "text": "The Longshot is the most\nadvanced spacecraft ever built.",
    "start": 218.3,
    "duration": 3.47
  },
  {
    "text": "And in it, Commander\nKane will travel to Mars.",
    "start": 221.77,
    "duration": 3.04
  },
  {
    "text": "A journey that, according to NASA,",
    "start": 224.81,
    "duration": 1.85
  },
  {
    "text": "will take just over three minutes.",
    "start": 226.66,
    "duration": 2.514
  },
  {
    "text": "- [Ethan] Lighting it up",
    "start": 229.174,
    "duration": 0.833
  },
  {
    "text": "in three, two, one.\n(engine whining)",
    "start": 230.007,
    "duration": 5.0
  },
  {
    "text": "Mark!",
    "start": 235.073,
    "duration": 0.833
  },
  {
    "text": "(people chattering)",
    "start": 239.873,
    "duration": 3.0
  },
  {
    "text": "(ethereal music)",
    "start": 247.484,
    "duration": 2.9
  },
  {
    "text": "(energy crackling)",
    "start": 250.384,
    "duration": 2.917
  },
  {
    "text": "(spaceship rumbling)",
    "start": 256.08,
    "duration": 3.083
  },
  {
    "text": "(tense music)",
    "start": 260.955,
    "duration": 2.5
  },
  {
    "text": "1.25 c.",
    "start": 271.123,
    "duration": 1.01
  },
  {
    "text": "Spinning down in five.",
    "start": 273.43,
    "duration": 1.42
  },
  {
    "text": "(spaceship whooshing)\n(engine whining)",
    "start": 278.655,
    "duration": 5.0
  },
  {
    "text": "Flight, do you copy?",
    "start": 291.88,
    "duration": 1.406
  },
  {
    "text": "(Mission Control applauding)\n- That's right, yes!",
    "start": 293.286,
    "duration": 4.447
  },
  {
    "text": "- Loud and clear, Commander.",
    "start": 297.733,
    "duration": 1.4
  },
  {
    "text": "Welcome back to our corner of space-time.",
    "start": 300.06,
    "duration": 3.14
  },
  {
    "text": "- [Ethan] It's good to be back.",
    "start": 303.2,
    "duration": 1.95
  },
  {
    "text": "- And this just in!",
    "start": 305.15,
    "duration": 1.53
  },
  {
    "text": "Commander Kane has\narrived at his destination",
    "start": 306.68,
    "duration": 2.61
  },
  {
    "text": "and is now the first man to\ntravel faster than light.",
    "start": 309.29,
    "duration": 3.876
  },
  {
    "text": "- Thank God!",
    "start": 313.166,
    "duration": 0.934
  },
  {
    "text": "- [Reporter] The commander will now launch",
    "start": 314.1,
    "duration": 1.64
  },
  {
    "text": "an entangled satellite\ninto orbit around Mars",
    "start": 315.74,
    "duration": 3.01
  },
  {
    "text": "allowing real-time communication",
    "start": 318.75,
    "duration": 1.86
  },
  {
    "text": "between Earth and Mars Colony One.",
    "start": 320.61,
    "duration": 2.171
  },
  {
    "text": "(dramatic music)",
    "start": 322.781,
    "duration": 2.75
  },
  {
    "text": "- Q sat, online.",
    "start": 327.73,
    "duration": 1.103
  },
  {
    "text": "- [Ethan] All right, let's do this again",
    "start": 330.54,
    "duration": 1.937
  },
  {
    "text": "before you miss me too much.",
    "start": 332.477,
    "duration": 1.4
  },
  {
    "text": "- Initiate return sequence.",
    "start": 335.63,
    "duration": 1.563
  },
  {
    "text": "- [Ethan] Starting FTL spin-up sequence.",
    "start": 338.14,
    "duration": 2.05
  },
  {
    "text": "- [Sarah] Roger that, Longshot.",
    "start": 340.19,
    "duration": 1.55
  },
  {
    "text": "(spaceship humming)",
    "start": 343.901,
    "duration": 3.083
  },
  {
    "text": "- And we are a go across\nthe board, Flight.",
    "start": 351.27,
    "duration": 2.047
  },
  {
    "text": "- [Sarah] Spin her up, Commander.",
    "start": 353.317,
    "duration": 2.714
  },
  {
    "text": "(engine whining)",
    "start": 356.031,
    "duration": 2.75
  },
  {
    "text": "- Flight, it looks like I may\nhave an interlock issue here.",
    "start": 362.061,
    "duration": 2.949
  },
  {
    "text": "- We're seeing the same thing here.",
    "start": 365.01,
    "duration": 1.51
  },
  {
    "text": "Let's take a look at diagnostics.",
    "start": 366.52,
    "duration": 1.873
  },
  {
    "text": "Abort FTL drive start and spin down.",
    "start": 370.7,
    "duration": 2.483
  },
  {
    "text": "- Roger that.",
    "start": 374.1,
    "duration": 0.833
  },
  {
    "text": "Spinning down.",
    "start": 375.83,
    "duration": 0.833
  },
  {
    "text": "(computer beeping)",
    "start": 387.638,
    "duration": 2.592
  },
  {
    "text": "Flight, we have a problem.",
    "start": 390.23,
    "duration": 0.999
  },
  {
    "text": "(spaceship whooshing)",
    "start": 391.229,
    "duration": 3.167
  },
  {
    "text": "(alarm beeping)",
    "start": 395.662,
    "duration": 3.058
  },
  {
    "text": "(energy crackling)\n(dramatic music)",
    "start": 398.72,
    "duration": 5.0
  },
  {
    "text": "Flight, I have lost drive control.",
    "start": 405.06,
    "duration": 1.47
  },
  {
    "text": "Repeat, I have lost drive control.",
    "start": 406.53,
    "duration": 2.093
  },
  {
    "text": "I have no nav comm and I\nam approaching light speed.",
    "start": 410.322,
    "duration": 3.021
  },
  {
    "text": "- Find him, Comms!",
    "start": 419.626,
    "duration": 1.873
  },
  {
    "text": "- [Ethan] I am being\npulled in to a new vector!",
    "start": 421.499,
    "duration": 3.917
  },
  {
    "text": "- [Computer] Warning, hull breach.",
    "start": 428.028,
    "duration": 1.843
  },
  {
    "text": "Warning, hull breach.",
    "start": 429.871,
    "duration": 1.853
  },
  {
    "text": "Warning, hull breach.",
    "start": 431.724,
    "duration": 1.868
  },
  {
    "text": "Warning.",
    "start": 433.592,
    "duration": 1.425
  },
  {
    "text": "(metal groaning)\n(engine whining)",
    "start": 435.017,
    "duration": 5.0
  },
  {
    "text": "(spaceship whooshing)",
    "start": 442.067,
    "duration": 3.167
  },
  {
    "text": "Warning, hull breach.",
    "start": 448.833,
    "duration": 1.75
  },
  {
    "text": "Warning, hull breach.",
    "start": 451.906,
    "duration": 1.75
  },
  {
    "text": "Warning.",
    "start": 454.78,
    "duration": 0.833
  },
  {
    "text": "(ethereal music)\n(spaceship rumbling)",
    "start": 457.434,
    "duration": 5.0
  },
  {
    "text": "Warning, hull breach.",
    "start": 492.099,
    "duration": 1.75
  },
  {
    "text": "Warning, hull breach.",
    "start": 495.22,
    "duration": 1.75
  },
  {
    "text": "- I need information people, come on!",
    "start": 499.99,
    "duration": 1.98
  },
  {
    "text": "Where's our bird?",
    "start": 501.97,
    "duration": 0.86
  },
  {
    "text": "- Gone, I mean gone.",
    "start": 502.83,
    "duration": 1.67
  },
  {
    "text": "No vector, nothing to track.",
    "start": 504.5,
    "duration": 1.67
  },
  {
    "text": "We should be able to get him",
    "start": 506.17,
    "duration": 0.833
  },
  {
    "text": "on Q comm anywhere, but nothing.",
    "start": 507.003,
    "duration": 1.517
  },
  {
    "text": "- Stand by, we're receiving\nsome new information.",
    "start": 512.43,
    "duration": 3.113
  },
  {
    "text": "Commander Kane seems to have disappeared.",
    "start": 516.76,
    "duration": 2.083
  },
  {
    "text": "- Where did Dad go?",
    "start": 519.91,
    "duration": 1.3
  },
  {
    "text": "- [Reporter] The Longshot\nwas ready to make",
    "start": 521.21,
    "duration": 1.35
  },
  {
    "text": "the return voyage home",
    "start": 522.56,
    "duration": 1.53
  },
  {
    "text": "but something seems to have gone wrong.",
    "start": 524.09,
    "duration": 2.04
  },
  {
    "text": "We will continue to follow the story",
    "start": 526.13,
    "duration": 1.89
  },
  {
    "text": "and provide updates on\nany new developments.",
    "start": 528.02,
    "duration": 2.848
  },
  {
    "text": "(tense music)",
    "start": 530.868,
    "duration": 2.5
  },
  {
    "text": "- [Computer] Warning, hull breach.",
    "start": 537.014,
    "duration": 2.165
  },
  {
    "text": "- A first contact.",
    "start": 539.179,
    "duration": 1.496
  },
  {
    "text": "Okay, way above my pay grade.",
    "start": 540.675,
    "duration": 1.996
  },
  {
    "text": "- [Computer] Warning, hull breach.",
    "start": 542.671,
    "duration": 2.833
  },
  {
    "text": "Warning, hull breach.\n(glass cracking)",
    "start": 554.087,
    "duration": 2.822
  },
  {
    "text": "Warning, hull breach.\n(metal groaning)",
    "start": 556.909,
    "duration": 5.0
  },
  {
    "text": "(sad music)\n(glass cracking)",
    "start": 566.057,
    "duration": 5.0
  },
  {
    "text": "(aliens buzzing)",
    "start": 591.264,
    "duration": 2.75
  },
  {
    "text": "(metal groaning)",
    "start": 599.979,
    "duration": 2.75
  },
  {
    "text": "(aliens buzzing)",
    "start": 609.74,
    "duration": 2.75
  },
  {
    "text": "- [Reporter] After almost a day",
    "start": 642.761,
    "duration": 1.148
  },
  {
    "text": "since his last communication,",
    "start": 643.909,
    "duration": 1.721
  },
  {
    "text": "the search for Commander Kane continues.",
    "start": 645.63,
    "duration": 2.293
  },
  {
    "text": "We have reached out for the\nCommander's family for comment.",
    "start": 648.83,
    "duration": 3.451
  },
  {
    "text": "We're sure it's been a\ndifficult time for them.",
    "start": 652.281,
    "duration": 2.809
  },
  {
    "text": "Along with the rest of the world,",
    "start": 655.09,
    "duration": 1.52
  },
  {
    "text": "we hold out hope for a safe return.",
    "start": 656.61,
    "duration": 2.573
  },
  {
    "text": "- [Sarah] Nothing more to do today.",
    "start": 678.176,
    "duration": 2.744
  },
  {
    "text": "Go home.",
    "start": 680.92,
    "duration": 0.833
  },
  {
    "text": "(radio squelching)",
    "start": 688.236,
    "duration": 3.313
  },
  {
    "text": "- Uh, Flight?",
    "start": 691.549,
    "duration": 1.083
  },
  {
    "text": "There's something.",
    "start": 694.09,
    "duration": 1.11
  },
  {
    "text": "- [Ethan] Control, come in.",
    "start": 695.2,
    "duration": 2.25
  },
  {
    "text": "- You guys getting this?",
    "start": 698.38,
    "duration": 1.2
  },
  {
    "text": "- [NavCom] NORAD is reporting an anomaly",
    "start": 701.32,
    "duration": 1.21
  },
  {
    "text": "approximately 2.4 clicks from ISS.",
    "start": 702.53,
    "duration": 2.71
  },
  {
    "text": "- Anomaly?",
    "start": 705.24,
    "duration": 0.833
  },
  {
    "text": "Do we have a visual?",
    "start": 706.073,
    "duration": 0.833
  },
  {
    "text": "- Coming up.",
    "start": 706.906,
    "duration": 1.157
  },
  {
    "text": "(dramatic music)",
    "start": 709.947,
    "duration": 2.75
  },
  {
    "text": "- What is that?",
    "start": 714.504,
    "duration": 1.25
  },
  {
    "text": "(aliens whizzing)",
    "start": 725.945,
    "duration": 2.833
  },
  {
    "text": "Can you track?",
    "start": 739.877,
    "duration": 0.833
  },
  {
    "text": "- I don't.",
    "start": 740.71,
    "duration": 5.0
  },
  {
    "text": "(air whooshing)",
    "start": 745.94,
    "duration": 2.667
  },
  {
    "text": "- [Abby] Jack!",
    "start": 751.339,
    "duration": 1.167
  },
  {
    "text": "Jack!",
    "start": 755.326,
    "duration": 0.833
  },
  {
    "text": "(aliens buzzing)",
    "start": 757.75,
    "duration": 0.833
  },
  {
    "text": "- [Jack] Whoa.",
    "start": 758.583,
    "duration": 1.167
  },
  {
    "text": "(Ethan gasps)",
    "start": 779.624,
    "duration": 1.108
  },
  {
    "text": "(dramatic music)",
    "start": 780.732,
    "duration": 2.75
  },
  {
    "text": "Daddy!",
    "start": 793.717,
    "duration": 0.833
  },
  {
    "text": "- It's me, it's me!",
    "start": 809.717,
    "duration": 1.667
  },
  {
    "text": "(Abby sobbing)",
    "start": 814.929,
    "duration": 2.583
  },
  {
    "text": "(sullen music)",
    "start": 869.002,
    "duration": 2.583
  }
]