  {
    "text": "Forgive me, my love.",
    "start": 290.29,
    "duration": 1.835
  },
  {
    "text": "Lincoln, why are you wearing my leggings?",
    "start": 294.086,
    "duration": 2.753
  },
  {
    "text": "Hey, you never said\nI had to wear my pants.",
    "start": 296.922,
    "duration": 3.211
