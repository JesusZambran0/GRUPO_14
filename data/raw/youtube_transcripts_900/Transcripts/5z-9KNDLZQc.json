  {
    "text": "[buzzer]",
    "start": 267.1,
    "duration": 0.876
  },
  {
    "text": "Buh-bye.",
    "start": 268.06,
    "duration": 1.209
  },
  {
    "text": "[groaning]",
    "start": 273.023,
    "duration": 1.335
  },
  {
    "text": "Maybe the pants are the problem.",
    "start": 274.525,
    "duration": 1.584
  },
  {
    "text": "Too scratchy. Too tight.",
    "start": 277.528,
    "duration": 2.752
  },
  {
    "text": "Too far after Labor Day.",
    "start": 280.656,
    "duration": 2.002
  },
  {
    "text": "Oh, these are perfect.",
    "start": 283.116,
    "duration": 1.627
  },
  {
    "text": "Babe! Why aren't you\nanswering my calls?",
    "start": 284.826,
    "duration": 3.796
