  {
    "text": "I'M BATMAN! I AM GROOOOOOT!",
    "start": 318.673,
    "duration": 1.9
  },
  {
    "text": "*cough*",
    "start": 320.64,
    "duration": 0.56
  },
  {
    "text": "I'm getting the hiccups.",
    "start": 321.2,
    "duration": 0.62
  },
  {
    "text": "G.I.Joe got a movie too!",
    "start": 322.54,
    "duration": 1.88
  },
  {
    "text": "Man, the future is awesome!",
    "start": 324.733,
    "duration": 1.84
  },
  {
    "text": "I need to see these movies right now!",
    "start": 326.573,
    "duration": 2.38
  },
  {
    "text": "Awe...",
    "start": 331.28,
    "duration": 0.7
  },
  {
    "text": "Well... now I know...",
    "start": 332.751,
    "duration": 1.44
  },
  {
    "text": "and knowing is half the battle.",
    "start": 335.72,
    "duration": 1.58
  },
  {
    "text": "I am Groot.",
    "start": 337.4,
    "duration": 1.14
  },
  {
    "text": "Who the heck did planted all these groots?!",
    "start": 361.28,
