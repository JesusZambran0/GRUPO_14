    "text": "Whoa!",
    "start": 60.686,
    "duration": 1.793
  },
  {
    "text": "Great job, Mighty Ella.",
    "start": 63.647,
    "duration": 1.668
  },
  {
    "text": "Rubble, I have to help\nRocky with these cables.",
    "start": 65.44,
    "duration": 2.336
