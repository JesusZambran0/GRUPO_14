  {
    "text": "He needs to help save Mayor Goodway.",
    "start": 70.988,
    "duration": 1.585
  },
  {
    "text": "You got it, Ryder.",
    "start": 72.739,
    "duration": 1.544
  },
  {
    "text": "Thanks, sis!",
    "start": 81.456,
    "duration": 1.085
  },
  {
    "text": "We always have each other's backs.",
    "start": 83.041,
    "duration": 2.211
  },
  {
    "text": "These lasers are big trouble.",
    "start": 94.261,
    "duration": 1.919
