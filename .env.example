# Variables opcionales. La demo funciona sin ninguna de ellas (modo manual + reglas locales).

# YouTube Data API v3 — opcional, solo para autocompletar metadatos del video
YOUTUBE_API_KEY=

# LLM local pequeño (Qwen2.5-1.5B-Instruct o SmolLM2-1.7B-Instruct).
# Si no se descarga, el sistema usa rule_based_recommendation automáticamente.
LLM_LOCAL_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct
# LLM_LOCAL_MODEL_ID=HuggingFaceTB/SmolLM2-1.7B-Instruct
LLM_LOCAL_MAX_NEW_TOKENS=512
LLM_LOCAL_OFFLINE=1

# Transcripción local con faster-whisper
WHISPER_MODEL_SIZE=tiny           # tiny | base | small
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cpu

# CPM por defecto (USD)
DEFAULT_CPM=5.0

# Limites de procesamiento de demo
MAX_VIDEO_DURATION_SECONDS=300
MAX_OCR_FRAMES=20

# Entrenamiento
ENABLE_HGB=0
MODEL_TIMEOUT_S=180
MAX_TRAIN_ROWS=0
GEMINI_MODEL=gemini-2.5-flash
ENABLE_LOCAL_LLM=false
LOCAL_LLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct
LOCAL_LORA_PATH=models/qwen_marketing_qlora
